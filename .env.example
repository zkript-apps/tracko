# MongoDB
MONGODB_URI=mongodb://tracko:tracko_dev_password@localhost:27017/tracko?authSource=admin

# API (NestJS)
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
# Production example (Render):
# API_URL=https://tracko-api-ey3l.onrender.com
# WEB_URL=https://tracko-web.vercel.app
# TRUSTED_ORIGINS=https://tracko-web.vercel.app,http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Comma-separated browser origins allowed to call the API (include production web URL)
TRUSTED_ORIGINS=http://localhost:3000
PAYMENT_WEBHOOK_SECRET=replace-with-a-secure-webhook-secret
PLATFORM_BOOTSTRAP_SECRET=replace-with-a-secure-bootstrap-secret-for-first-super-admin

# Email (Resend) — optional in dev; logs invite links to console when unset
RESEND_API_KEY=
EMAIL_FROM=WorkTrack <onboarding@resend.dev>

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
# Production (Vercel): proxy API through the web domain so auth cookies work in all browsers.
# NEXT_PUBLIC_USE_API_PROXY=true
# API_URL=https://tracko-api-ey3l.onrender.com
# NEXT_PUBLIC_WEB_URL=https://tracko-web.vercel.app
# Optional fallback when the proxy is disabled:
# NEXT_PUBLIC_API_URL=https://tracko-api-ey3l.onrender.com
